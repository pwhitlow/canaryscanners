# Thinkst Canary API Configuration
# Copy this file to .env and fill in your credentials

# Your Canary console domain
# Can be with or without https:// prefix
# Examples:
#   1234abc.canary.tools
#   https://1234abc.canary.tools
CANARY_CONSOLE_DOMAIN=your-console.canary.tools

# Your API key from the Canary console
CANARY_API_KEY=your-api-key-here
